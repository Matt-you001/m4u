{
  "expo": {
    "name": "Message4u",
    "slug": "m4u",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "m4u",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mattonah.message4u",
      "buildNumber": "1",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow Message4u to turn your voice prompt into text.",
        "NSMicrophoneUsageDescription": "Allow Message4u to use your microphone for voice prompts.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "package": "com.mattonah.message4u",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-google-signin/google-signin",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-8208154537756936~9573605827",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Message4u to use your microphone for voice prompts.",
          "speechRecognitionPermission": "Allow Message4u to turn your voice prompt into text."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "revenuecat": {
        "testApiKey": "test_hAUFSXISuwFRqhWKUcatrdmbimr",
        "androidApiKey": "goog_QOIJOUpuYylDMEyMNsgqaXRophJ",
        "iosApiKey": "",
        "basicEntitlementId": "entl48c716552a",
        "premiumEntitlementId": "entl459591f140",
        "offeringIdentifier": "default"
      },
      "admob": {
        "androidBannerAdUnitId": "ca-app-pub-8208154537756936/1261241232",
        "iosBannerAdUnitId": "ca-app-pub-3940256099942544/2435281174",
        "androidInterstitialAdUnitId": "ca-app-pub-8208154537756936/4426797335",
        "iosInterstitialAdUnitId": "ca-app-pub-3940256099942544/4411468910",
        "androidRewardedAdUnitId": "ca-app-pub-8208154537756936/6861388989",
        "iosRewardedAdUnitId": "ca-app-pub-3940256099942544/1712485313"
      },
      "eas": {
        "projectId": "39b5dff0-684e-46b4-996d-9840d4defe6d"
      }
    },
    "owner": "mattonah"
  }
}
